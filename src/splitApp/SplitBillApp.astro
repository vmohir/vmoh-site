---
import AppHeader from './AppHeader';
import PeopleSection from '../people/PeopleSection';
import ItemsSection from '../receiptItems/ItemsSection';
import AdjustmentsSection from './AdjustmentsSection';
import ResultsSection from './ResultsSection';
---

<div class="split-bill-container">
  <AppHeader client:load />

  <section class="people-section">
    <PeopleSection client:load />
  </section>

  <section class="items-section">
    <h2>Items</h2>
    <ItemsSection client:load />
  </section>

  <section class="adjustments-section">
    <h2>Adjustments</h2>
    <AdjustmentsSection client:load />
  </section>

  <section class="results-section">
    <h2>Results</h2>
    <ResultsSection client:load />
  </section>
</div>

<script>
  // Mobile WebKit (iOS Safari/Brave) doesn't blur a focused field when you tap
  // an inert area the way desktop browsers do — only interactive elements
  // dismiss focus. Restore the expected behaviour: a tap on something
  // non-interactive commits and blurs the active input/textarea.
  //
  // Decide on pointerup (not pointerdown) and only when the pointer barely
  // moved, so starting a scroll on empty space doesn't blur the field — a
  // scroll either moves past the threshold or fires pointercancel instead of
  // pointerup.
  const INTERACTIVE =
    "input, textarea, select, button, a, label, summary, [contenteditable], [tabindex], [role]";
  const TAP_SLOP = 8;
  let startX = 0;
  let startY = 0;
  document.addEventListener("pointerdown", (e) => {
    startX = e.clientX;
    startY = e.clientY;
  });
  document.addEventListener("pointerup", (e) => {
    const active = document.activeElement;
    if (
      !(active instanceof HTMLInputElement) &&
      !(active instanceof HTMLTextAreaElement)
    )
      return;
    if (
      Math.abs(e.clientX - startX) > TAP_SLOP ||
      Math.abs(e.clientY - startY) > TAP_SLOP
    )
      return;
    const target = e.target;
    if (target instanceof Element && target.closest(INTERACTIVE)) return;
    active.blur();
  });
</script>

<style>
  @reference "../styles/global.css";
  .split-bill-container {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    padding: 1.5rem 1rem 6rem;
    max-width: 640px;
    margin: 0 auto;
  }

  section {
    @apply flex flex-col gap-3;
  }
</style>

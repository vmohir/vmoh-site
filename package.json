{
  "name": "vmoh-site",
  "version": "1.0.0",
  "description": "Personal site for Vahid Mohammadi",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build:homepage": "pnpm --filter @vmoh-site/homepage build",
    "build:old-homepage": "cd packages/old-homepage && npm run build",
    "build": "npm run build:homepage && npm run build:old-homepage",
    "build:split-bill": "pnpm --filter splitted build",
    "build:chooser": "pnpm --filter chooser-online build",
    "build:vaje-games": "pnpm --filter vaje-games build",
    "build:slides": "cd packages/slides && pnpm install --frozen-lockfile && pnpm run build"
  },
  "devDependencies": {
    "netlify-cli": "^26.2.0",
    "prettier": "^3.9.5"
  }
}
